config image-path ../../../../../inet/images:../../../../../veins/images
config network Scenario
config sim-time-limit 60s
config debug-on-errors true
config cmdenv-express-mode true
config image-path ../../../../images
config Scenario.node[*].numUdpApps 1
config Scenario.node[*].udpApp[0].typename UDPBasicApp
config Scenario.node[*].udpApp[0].destAddresses "\"224.0.0.1\""
config Scenario.node[*].udpApp[0].multicastInterface "\"wlan0\""
config Scenario.node[*].udpApp[0].joinLocalMulticastGroups true
config Scenario.node[*].udpApp[0].localPort 9001
config Scenario.node[*].udpApp[0].destPort 9001
config Scenario.node[*].udpApp[0].messageLength 100B
config Scenario.node[*].udpApp[0].startTime "uniform(0s, 5s)"
config Scenario.node[*].udpApp[0].sendInterval 5s
config Scenario.node[*].wlan[0].mgmtType "\"Ieee80211MgmtAdhoc\""
config Scenario.node[*].wlan[0].bitrate 6Mbps
config Scenario.node[*].wlan[0].radio.transmitter.power 2mW
config Scenario.node[*].ac_wlan.interfaces "\"wlan0\""
config Scenario.node[*].ac_wlan.mcastGroups "\"224.0.0.1\""
config Scenario.node[*].mobilityType "\"VeinsInetMobility\""
config Scenario.node[*].mobility.constraintAreaMinX 0m
config Scenario.node[*].mobility.constraintAreaMinY 0m
config Scenario.node[*].mobility.constraintAreaMinZ 0m
config Scenario.node[*].mobility.constraintAreaMaxX 1000m
config Scenario.node[*].mobility.constraintAreaMaxY 1000m
config Scenario.node[*].mobility.constraintAreaMaxZ 0m
config Scenario.manager.updateInterval 0.1s
config Scenario.manager.host "\"localhost\""
config Scenario.manager.port 9999
config Scenario.manager.autoShutdown true
config Scenario.manager.launchConfig "xmldoc(\"square.launchd.xml\")"
config Scenario.manager.moduleType "\"vanet_tutorials.simulations.veins_inet3.examples.veins_inet.Car\""
config **.vector-recording true

